{
  "name": "env-nextjs",
  "description": "Environment variable validation for Next.js",
  "version": "1.0.1",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.5.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@commitlint/types": "^21.0.1",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/node": "^25.9.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "release-it": "^20.2.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "zod3-max": "npm:zod@3",
    "zod3-min": "npm:zod@3.0.0",
    "zod4-max": "npm:zod@4",
    "zod4-min": "npm:zod@4.0.0"
  },
  "peerDependencies": {
    "zod": "^3 || ^4"
  },
  "scripts": {
    "build": "tsc --project .config/tsconfig.build.json",
    "clean": "rimraf dist/",
    "prepare": "husky",
    "test": "vitest --config .config/vitest.config.ts run"
  }
}
