{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowJs": true,
    "checkJs": true,
    "types": ["node"],
    "skipLibCheck": true,
    "strict": true,
    "isolatedModules": true,
    "noPropertyAccessFromIndexSignature": true,
    "paths": {
      "@/*": ["../*"]
    }
  },
  "exclude": ["../node_modules", "../dist"]
}
